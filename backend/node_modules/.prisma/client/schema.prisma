generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String?
  role     String  @default("USER")

  cases         Case[] @relation("submittedCases")
  assignedCases Case[] @relation("assignedCases")
  votes         Vote[]
}

model Case {
  id          Int      @id @default(autoincrement())
  trackingId  String   @unique
  category    String
  department  String
  location    String
  severity    String
  anonymous   Boolean  @default(false)
  description String
  status      String   @default("New")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId     Int?
  assignedTo Int?

  user         User? @relation("submittedCases", fields: [userId], references: [id])
  assignedUser User? @relation("assignedCases", fields: [assignedTo], references: [id])
}

model Poll {
  id        Int      @id @default(autoincrement())
  question  String
  options   String // Stored as JSON string
  createdAt DateTime @default(now())
  votes     Vote[]
}

model Vote {
  id     Int @id @default(autoincrement())
  userId Int
  pollId Int
  option Int // Index of chosen option

  user User @relation(fields: [userId], references: [id])
  poll Poll @relation(fields: [pollId], references: [id])

  @@unique([userId, pollId])
}
