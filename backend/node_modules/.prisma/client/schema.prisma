generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String
  role     String @default("USER")
}

model Case {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  description String
  title       String
}

model Poll {
  id        Int      @id @default(autoincrement())
  question  String
  createdAt DateTime @default(now())
}
