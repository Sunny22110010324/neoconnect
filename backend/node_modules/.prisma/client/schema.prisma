model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Case {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  createdAt   DateTime @default(now())
}

model Poll {
  id        Int      @id @default(autoincrement())
  question  String
  createdAt DateTime @default(now())
}
